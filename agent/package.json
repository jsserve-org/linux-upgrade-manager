{
  "name": "lum-agent",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "bun run agent.ts",
    "build": "bun run build.ts",
    "build:linux-x64": "bun build ./agent.ts --compile --minify --sourcemap --target=bun-linux-x64 --outfile dist/lum-agent-linux-x64",
    "build:linux-arm64": "bun build ./agent.ts --compile --minify --sourcemap --target=bun-linux-arm64 --outfile dist/lum-agent-linux-arm64"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  }
}
