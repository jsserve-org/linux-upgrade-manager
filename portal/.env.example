DATABASE_URL=postgres://lum:lum@localhost:5432/lum

# Seed an enrollment token on first boot (optional)
ENROLL_TOKEN=changeme

# ── better-auth · Authentik OIDC ─────────────────────────────────────────────
# When all three OAUTH_* values are set, the UI requires sign-in via Authentik.
# When unset, the hub runs without auth (dev mode).
BETTER_AUTH_SECRET=<openssl rand -base64 32>
BETTER_AUTH_URL=http://localhost:3001
# Comma-separated additional trusted origins, optional:
# BETTER_AUTH_TRUSTED_ORIGINS=https://hub.example.com

# Authentik issuer URL — the per-application OIDC base, WITHOUT the
# /.well-known/openid-configuration suffix. We append that ourselves.
# Format:  https://<authentik-host>/application/o/<application-slug>
OAUTH_ISSUER=https://auth.example.com/application/o/lum-portal
OAUTH_CLIENT_ID=<from the Authentik OAuth2/OIDC provider — "Client ID">
OAUTH_CLIENT_SECRET=<from the Authentik OAuth2/OIDC provider — "Client Secret">
# Default: "openid email profile"
# OAUTH_SCOPES=openid email profile

# ── CVE sync ─────────────────────────────────────────────────────────────────
# LUM_DISABLE_CVE_SYNC=1
# NVD_API_KEY=
