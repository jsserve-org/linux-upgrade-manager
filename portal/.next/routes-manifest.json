{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/admin/enroll-tokens/[token]",
      "regex": "^/api/admin/enroll\\-tokens/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtoken": "nxtPtoken"
      },
      "namedRegex": "^/api/admin/enroll\\-tokens/(?<nxtPtoken>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/admin/instances/[id]",
      "regex": "^/api/admin/instances/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/admin/instances/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/agent/jobs/[id]/report",
      "regex": "^/api/agent/jobs/([^/]+?)/report(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/agent/jobs/(?<nxtPid>[^/]+?)/report(?:/)?$"
    },
    {
      "page": "/api/auth/[...all]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPall": "nxtPall"
      },
      "namedRegex": "^/api/auth/(?<nxtPall>.+?)(?:/)?$"
    },
    {
      "page": "/api/install/agent/[arch]",
      "regex": "^/api/install/agent/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtParch": "nxtParch"
      },
      "namedRegex": "^/api/install/agent/(?<nxtParch>[^/]+?)(?:/)?$"
    },
    {
      "page": "/cves/[id]",
      "regex": "^/cves/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/cves/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/instances/[id]",
      "regex": "^/instances/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/instances/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/api/admin/cves",
      "regex": "^/api/admin/cves(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/admin/cves(?:/)?$"
    },
    {
      "page": "/api/admin/cves/sync",
      "regex": "^/api/admin/cves/sync(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/admin/cves/sync(?:/)?$"
    },
    {
      "page": "/api/admin/enroll-tokens",
      "regex": "^/api/admin/enroll\\-tokens(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/admin/enroll\\-tokens(?:/)?$"
    },
    {
      "page": "/api/admin/jobs",
      "regex": "^/api/admin/jobs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/admin/jobs(?:/)?$"
    },
    {
      "page": "/api/agent/enroll",
      "regex": "^/api/agent/enroll(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/agent/enroll(?:/)?$"
    },
    {
      "page": "/api/agent/heartbeat",
      "regex": "^/api/agent/heartbeat(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/agent/heartbeat(?:/)?$"
    },
    {
      "page": "/api/agent/jobs",
      "regex": "^/api/agent/jobs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/agent/jobs(?:/)?$"
    },
    {
      "page": "/cves",
      "regex": "^/cves(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/cves(?:/)?$"
    },
    {
      "page": "/enroll",
      "regex": "^/enroll(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/enroll(?:/)?$"
    },
    {
      "page": "/install.sh",
      "regex": "^/install\\.sh(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/install\\.sh(?:/)?$"
    },
    {
      "page": "/instances",
      "regex": "^/instances(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/instances(?:/)?$"
    },
    {
      "page": "/jobs",
      "regex": "^/jobs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/jobs(?:/)?$"
    },
    {
      "page": "/sign-in",
      "regex": "^/sign\\-in(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sign\\-in(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}