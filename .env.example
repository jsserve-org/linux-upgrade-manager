# ============================================
# Linux Upgrade Manager - Environment Config
# ============================================

# Database Configuration
POSTGRES_USER=lum
POSTGRES_PASSWORD=changeme-strong-password-here
POSTGRES_DB=lum
POSTGRES_PORT=5432

# Portal Configuration
PORTAL_PORT=3001
NODE_ENV=production

# Better Auth - Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here-min-32-chars-long
BETTER_AUTH_URL=http://localhost:3001

# Enrollment Token - Used for agent enrollment
# Change this to a secure random string for production
ENROLL_TOKEN=changeme

# ============================================
# Optional: Authentik SSO Configuration
# Leave empty to disable SSO (dev mode with local auth)
# ============================================

# OAuth Provider Settings
# OAUTH_ISSUER=https://auth.example.com/application/o/lum-portal
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret

# ============================================
# Optional: External Database URL (overrides individual settings)
# DATABASE_URL=postgres://lum:password@localhost:5432/lum
# ============================================
